      ],
      "tool": {
        "driver": {
          "name": "repo-sentinel-lite",
          "rules": [
            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "Detects required repository files that are missing."
              },
              "id": "repo.required_file_missing",
              "name": "Missing Required File",
              "properties": {
                "kind": "missing_file",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "Required repository file missing."
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Detects suspicious filenames commonly associated with secrets."
              },
              "id": "repo.suspicious_filename",
              "name": "Suspicious Filename",
              "properties": {
                "kind": "suspicious_file",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "Suspicious filename detected."
              }
            },
            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "Detects assignment contexts such as token=, api_key=, or password= with a non-placeholder value."
              },
              "id": "secret.assignment_context",
              "name": "Secret Assignment Context",
              "properties": {
                "kind": "assignment_context",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "Secret-like assignment context detected."
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Detects AWS access-key-like identifiers by provider prefix and length. This is a heuristic and does not validate the credential."
              },
              "id": "secret.aws_access_key_id",
              "name": "AWS Access Key ID Pattern",
              "properties": {
                "kind": "aws_access_key_id",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "AWS access-key-like identifier detected."
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Detects GitHub token-like prefixes such as ghp_, gho_, ghs_, ghr_, ghu_, and github_pat_. This is a prefix heuristic."
              },
              "id": "secret.github_token",
              "name": "GitHub Token Prefix",
              "properties": {
                "kind": "github_token",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "GitHub token-like prefix detected."
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Detects high-entropy strings that may indicate secrets."
              },
              "id": "secret.high_entropy",
              "name": "High Entropy",
              "properties": {
                "kind": "high_entropy",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "High-entropy string detected."
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Detects PEM private-key headers. This does not parse the full key but flags the strongest local evidence quickly."
              },
              "id": "secret.pem_private_key",
              "name": "PEM Private Key Header",
              "properties": {
                "kind": "pem_private_key",
                "ruleVersion": "1"
              },
              "shortDescription": {
                "text": "PEM private-key header detected."
              }
            }
          ]
        }
      }
    }
  ],
  "version": "2.1.0"
}
