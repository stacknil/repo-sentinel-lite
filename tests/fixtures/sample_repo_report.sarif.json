        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "vault/archive.kdbx"
                }
              }
            }
          ],
          "message": {
            "text": "Suspicious file detected: vault/archive.kdbx"
          },
          "partialFingerprints": {
            "repoSentinelFingerprint": "e34a85d2ae98c2282bf0966deb449470edba292d20c0ca3e2f8c53972fe5fc59"
