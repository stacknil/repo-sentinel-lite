          "properties": {
            "kind": "missing_file",
            "ruleVersion": "1"
          },
          "ruleId": "repo.required_file_missing"
        },
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".env"
                }
              }
            }
          ],
          "message": {
            "text": "Suspicious file detected: .env"
