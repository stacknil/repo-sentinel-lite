{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "results": [
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "notes/tokens.txt"
                },
                "region": {
                  "startLine": 2
                }
              }
            }
          ],
          "message": {
            "text": "High-entropy string detected: notes/tokens.txt:2"
          },
          "partialFingerprints": {
            "repoSentinelFingerprint": "9d32570586e37a6005c9ce58edd091a56032dc3f38ae5c907033c17661286129"
          },
          "properties": {
            "kind": "high_entropy",
            "ruleVersion": "1"
          },
          "ruleId": "secret.high_entropy"
        },
        {
          "level": "warning",
